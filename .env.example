# =============================================================
# arremateai-vendor — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e ajuste os valores conforme o ambiente.

# --- Servidor ---
SERVER_PORT=8084

# --- Banco de Dados ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=arremateai
DB_USERNAME=arremateai
DB_PASSWORD=

# --- Upload de documentos ---
VENDOR_BASE_URL=http://localhost:8084

# --- Integrações de e-mail e frontend ---
EMAIL_USERNAME=
EMAIL_PASSWORD=
ADMIN_EMAIL=admin@arremateai.com
FRONTEND_URL=http://localhost:3000
